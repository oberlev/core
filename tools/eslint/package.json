{
  "name": "@oberlev/eslint",
  "type": "module",
  "version": "1.0.1",
  "description": "eslint configs",
  "author": {
    "name": "Daniil Oberlev",
    "url": "https://github.com/oberlev"
  },
  "license": "MIT",
  "homepage": "https://github.com/oberlev/core",
  "repository": {
    "url": "https://github.com/oberlev/core"
  },
  "bugs": {
    "url": "https://github.com/oberlev/core/issues"
  },
  "keywords": [
    "eslint",
    "react",
    "next",
    "vue",
    "typescript",
    "node"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/esm/index.d.mts"
    },
    "./next": {
      "import": "./dist/esm/next.mjs",
      "require": "./dist/cjs/next.cjs",
      "types": "./dist/esm/next.d.mts"
    },
    "./vue": {
      "import": "./dist/esm/vue.mjs",
      "require": "./dist/cjs/vue.cjs",
      "types": "./dist/esm/vue.d.mts"
    }
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/esm/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm type && pnpm build",
    "build": "tsdown",
    "lint": "eslint . --fix",
    "lint-inspector": "npx @eslint/config-inspector",
    "type": "tsc --noEmit",
    "format": "prettier --write .",
    "pretty": "pnpm type && pnpm lint && pnpm format"
  },
  "dependencies": {
    "@antfu/eslint-config": "7.7.0",
    "@eslint-react/eslint-plugin": "2.13.0",
    "@eslint/css": "1.0.0",
    "@next/eslint-plugin-next": "16.1.6",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@vue/compiler-sfc": "3.5.30",
    "eslint": "10.0.3",
    "eslint-flat-config-utils": "3.0.2",
    "eslint-plugin-better-tailwindcss": "4.3.2",
    "eslint-plugin-playwright": "2.9.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2"
  },
  "devDependencies": {
    "@oberlev/prettier": "*",
    "@oberlev/tsconfig": "workspace:*",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.8",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}

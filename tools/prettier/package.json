{
  "name": "@oberlev/prettier",
  "type": "module",
  "version": "1.0.1",
  "description": "prettier configs",
  "author": {
    "name": "Daniil Oberlev",
    "url": "https://github.com/oberlev"
  },
  "license": "MIT",
  "homepage": "https://github.com/oberlev/core",
  "repository": {
    "url": "https://github.com/oberlev/core"
  },
  "bugs": {
    "url": "https://github.com/oberlev/core/issues"
  },
  "keywords": [
    "prettier",
    "config"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/esm/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm type && pnpm build",
    "build": "tsdown",
    "lint": "eslint . --fix",
    "lint-inspector": "npx @eslint/config-inspector",
    "type": "tsc --noEmit",
    "format": "prettier --write .",
    "pretty": "pnpm type && pnpm lint && pnpm format"
  },
  "peerDependencies": {
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@oberlev/tsconfig": "^1.0.1",
    "typescript": "^5.9.3",
    "tsdown": "^0.6.1"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
